                {
                  "_type": "UMLModel",
                  "_id": "id-d69329db582749f3",
                  "_parent": {
                    "$ref": "id-be6b147233954d6d"
                  },
                  "name": "Scenarios detailles",
                  "ownedElements": [
                    {
                      "_type": "UMLModel",
                      "_id": "id-b657b4f086684f60",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-AUTH-01 - Login valide",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLModel",
                      "_id": "id-442981488ef14ec0",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-AUTH-02 - Login invalide + auto-blocage IP",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLModel",
                      "_id": "id-44e665d56b204e36",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-PAY-01 - Paiement abonnement valide",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLModel",
                      "_id": "id-f95e420770a14f30",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-PAY-02 - Rejet paiement cash par admin",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLModel",
                      "_id": "id-9641edb2c28f4ff7",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-OWN-01 - Ownership client interdit",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLModel",
                      "_id": "id-7add984a3a664809",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "SC-MAIN-01 - Maintenance bloque ecritures",
                      "ownedElements": []
                    },
                    {
                      "_type": "UMLActivityDiagram",
                      "_id": "id-b08020cf0d844b12",
                      "_parent": {
                        "$ref": "id-d69329db582749f3"
                      },
                      "name": "Scenarios detailles - Vue Analytique",
                      "ownedViews": [
                        {
                          "_type": "UMLTextView",
                          "_id": "id-3c685478fd1746f4",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;13;1",
                          "parentStyle": false,
                          "left": 40,
                          "top": 30,
                          "width": 1320,
                          "height": 52,
                          "text": "KYA - Scenarios detailles (Analyse)\\nRegle globale: aucune fonctionnalite metier sans authentification (401 si non connecte)"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-375b47ee91c9462c",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 40,
                          "top": 110,
                          "width": 620,
                          "height": 140,
                          "text": "SC-AUTH-01\\nActeur: ADMIN\\nPre: compte actif + IP non bloquee\\nFlux: login valide -> session/authContext cree\\nErreurs: credentials invalides -> 401\\nPost: acces autorise aux fonctionnalites metier"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-5eae2feccd3d4ec0",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 710,
                          "top": 110,
                          "width": 620,
                          "height": 140,
                          "text": "SC-AUTH-02\\nActeur: SUPER_ADMIN\\nPre: login valide\\nFlux: second-auth valide (TTL 30 min)\\nErreurs: mot de passe faux / TTL expire -> refus\\nPost: operations sensibles autorisees"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-4049fddc8c2a4214",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 40,
                          "top": 280,
                          "width": 620,
                          "height": 140,
                          "text": "SC-PAY-01\\nActeur: ADMIN\\nPre: mois requis calcule, methode autorisee\\nFlux: creation paiement -> pending -> webhook signed -> paid\\nErreurs: doublon (admin,month), methode invalide, cash interdit\\nPost: abonnement actif et audite"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-c87c666246734788",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 710,
                          "top": 280,
                          "width": 620,
                          "height": 140,
                          "text": "SC-OWN-01\\nActeur: ADMIN\\nPre: tentative acces client hors ownership\\nFlux: controle ownership sur route sensible\\nErreurs: acces interdit 403\\nPost: isolation stricte A/B des portefeuilles"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-b9887dffab6e4d46",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 40,
                          "top": 450,
                          "width": 620,
                          "height": 140,
                          "text": "SC-IMP-01\\nActeur: ADMIN/OPS\\nPre: fichier import upload\\nFlux: parse ligne -> validation -> create/update\\nErreurs: ligne invalide -> import_errors\\nPost: import_run resume (ok/ko) + tracabilite complete"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-ef69fcfff32e4dff",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;0",
                          "parentStyle": false,
                          "left": 710,
                          "top": 450,
                          "width": 620,
                          "height": 140,
                          "text": "SC-MAIN-01\\nActeur: SUPER_ADMIN/OPS\\nPre: maintenance activee\\nFlux: routes ecriture bloquees hors whitelist\\nErreurs: tentative ecriture -> 503/403 selon politique\\nPost: endpoints exemptes restent operationnels"
                        },
                        {
                          "_type": "UMLTextView",
                          "_id": "id-833d3dd0bbee45ad",
                          "_parent": {
                            "$ref": "id-b08020cf0d844b12"
                          },
                          "font": "Arial;12;1",
                          "parentStyle": false,
                          "left": 40,
                          "top": 625,
                          "width": 1290,
                          "height": 55,
                          "text": "Reference detaillee: docs/UML/01_Aspect_Fonctionnel/Analyse/04_Scenarios_Detailles.md"
                        }
                      ]
                    }
                  ]
                },
